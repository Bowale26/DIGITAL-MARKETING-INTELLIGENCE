rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default Deny Catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Hardened Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(ownerId) { return isSignedIn() && request.auth.uid == ownerId; }
    
    // Auth tokens never contain roles. Rules must look up roles in the /users collection.
    function getUserData() { 
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) { 
      let data = getUserData();
      return isSignedIn() && data != null && data.role == role; 
    }
    
    function isAdmin() { 
      return isSignedIn() && (hasRole('ADMIN') || request.auth.token.email == 'isadewum@gmail.com'); 
    }
    
    function isCompliance() { return hasRole('COMPLIANCE_OFFICER'); }
    function isCounsel() { return hasRole('LEGAL_COUNSEL'); }
    function isExecutive() { return hasRole('EXECUTIVE'); }

    // 2. User Profiles (RBAC Master)
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'name', 'role', 'status']) &&
             data.email is string && data.email.size() <= 256 &&
             data.name is string && data.name.size() <= 256 &&
             data.role in ['USER', 'ADMIN', 'COMPLIANCE_OFFICER', 'LEGAL_COUNSEL', 'EXECUTIVE'] &&
             data.status in ['TRIAL', 'EXPIRED', 'SUBSCRIBED', 'GRACE_PERIOD', 'active', 'suspended', 'pending'] &&
             (!data.keys().contains('plan') || data.plan in ['free', 'monthly', 'annual']) &&
             (!data.keys().contains('intent') || data.intent in ['HIGH', 'MEDIUM', 'LOW', 'POWER']) &&
             (!data.keys().contains('trialStartDate') || data.trialStartDate is int) &&
             (!data.keys().contains('trialEndDate') || data.trialEndDate is int) &&
             (!data.keys().contains('projectsCreated') || data.projectsCreated is int) &&
             (!data.keys().contains('featureUsage') || (
               data.featureUsage is map &&
               data.featureUsage.get('aiGenerations', 0) is int &&
               data.featureUsage.get('analyticsViews', 0) is int &&
               data.featureUsage.get('exports', 0) is int
             ));
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin() || isCounsel() || isCompliance();
      allow list: if isAdmin() || isCompliance();
      
      allow create: if isSignedIn() && isValidId(userId) && request.auth.uid == userId && 
                       isValidUser(incoming()) && 
                       incoming().role == 'USER' && 
                       incoming().createdAt == request.time &&
                       incoming().updatedAt == request.time;
      
      allow update: if isValidId(userId) && isValidUser(incoming()) && (
        // Action: User Profile Update (Non-sensitive and simulation-driven fields)
        (isOwner(userId) && 
         !incoming().diff(existing()).affectedKeys().hasAny(['email', 'role', 'createdAt']) &&
         incoming().updatedAt == request.time) ||
        
        // Action: Admin/Compliance Overrides (Sensitive fields)
        ((isAdmin() || isCompliance()) && 
         !incoming().diff(existing()).affectedKeys().hasAny(['email', 'createdAt']) &&
         incoming().updatedAt == request.time)
      );
    }

    // 3. Legal Intake Maturation (Action Based)
    function isValidIntake(data) {
      return data.keys().hasAll(['clientId', 'serviceId', 'status']) &&
             data.clientId is string && data.clientId.size() <= 128 &&
             isValidId(data.serviceId) &&
             data.status in ['draft', 'submitted', 'in_review', 'action_required', 'closed'] &&
             (!data.keys().contains('narrative') || (data.narrative is string && data.narrative.size() <= 25000));
    }

    match /matters/{matterId} {
      allow get: if isValidId(matterId) && (isOwner(existing().clientId) || isAdmin() || isCounsel());
      allow list: if isSignedIn() && (resource.data.clientId == request.auth.uid || isAdmin() || isCounsel());
      
      allow create: if isVerified() && isValidId(matterId) && isValidIntake(incoming()) &&
                       incoming().clientId == request.auth.uid &&
                       incoming().createdAt == request.time;
                      
      allow update: if isVerified() && isValidId(matterId) && isValidIntake(incoming()) && (
        // Action: Submission
        (isOwner(existing().clientId) && existing().status == 'draft' && 
         incoming().status == 'submitted' && 
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) &&
         incoming().updatedAt == request.time) ||
         
        // Action: Legal Review
        ((isCounsel() || isAdmin()) && 
         incoming().diff(existing()).affectedKeys().hasAny(['status', 'internal_notes', 'updatedAt']) &&
         incoming().updatedAt == request.time) ||
        
        // Action: Client Response to Action Required
        (isOwner(existing().clientId) && existing().status == 'action_required' &&
         incoming().diff(existing()).affectedKeys().hasOnly(['narrative', 'updatedAt']) &&
         incoming().updatedAt == request.time)
      );
    }

    // 4. Governance Proposals (Multi-Gate Approval)
    function isValidProposal(data) {
      return data.keys().hasAll(['proposal_id', 'rule_target', 'risk_level', 'requester_id']) &&
             isValidId(data.proposal_id) &&
             data.rule_target is string && data.rule_target.size() <= 256 &&
             data.risk_level is int && data.risk_level >= 1 && data.risk_level <= 5 &&
             data.requester_id is string && data.requester_id.size() <= 128 &&
             (!data.keys().contains('description') || (data.description is string && data.description.size() <= 10000)) &&
             (!data.keys().contains('justification') || (data.justification is string && data.justification.size() <= 10000));
    }

    match /proposals/{proposalId} {
      allow get, list: if isSignedIn();
      allow create: if isVerified() && isValidId(proposalId) && isValidProposal(incoming()) && 
                       incoming().requester_id == request.auth.uid &&
                       incoming().timestamp == request.time &&
                       (isAdmin() || isCompliance() || isExecutive());
      
      allow update: if isVerified() && isValidId(proposalId) && isValidProposal(incoming()) && (
        // Action: Compliance Review
        (isCompliance() && incoming().diff(existing()).affectedKeys().hasOnly(['compliance_status', 'updatedAt']) && incoming().updatedAt == request.time) ||
        // Action: Executive Approval (Must be Compliance Approved first)
        (isExecutive() && existing().compliance_status == 'APPROVED' && 
         incoming().diff(existing()).affectedKeys().hasOnly(['final_status', 'updatedAt']) && incoming().updatedAt == request.time)
      );
    }

    // 5. Audit Trails (Write-Once / Root-Audit)
    function isValidGovernanceLog(data) {
      return data.keys().hasAll(['message', 'type', 'userId']) &&
             data.message is string && data.message.size() <= 5000 &&
             data.type is string && data.type.size() <= 128 &&
             data.userId is string && data.userId.size() <= 128;
    }

    match /governance_logs/{logId} {
      allow list: if isAdmin() || isCompliance();
      allow get: if isOwner(existing().userId) || isAdmin() || isCompliance();
      
      allow create: if isVerified() && isValidId(logId) && isValidGovernanceLog(incoming()) &&
                       incoming().userId == request.auth.uid && 
                       incoming().timestamp == request.time;
      allow update: if false; // Audit logs are immutable
      allow delete: if false; // Audit logs are permanent
    }

    // 6. Incidents (Emergency Protocol)
    function isValidIncident(data) {
      return data.keys().hasAll(['type', 'severity', 'reporterId']) &&
             data.type is string && data.type.size() <= 256 &&
             data.severity is string && data.severity.size() <= 128 &&
             data.reporterId is string && data.reporterId.size() <= 128;
    }

    match /incidents/{incidentId} {
      allow read: if isAdmin() || isCounsel() || isCompliance() || (isSignedIn() && resource.data.reporterId == request.auth.uid);
      
      allow create: if isVerified() && isValidId(incidentId) && isValidIncident(incoming()) &&
                       incoming().reporterId == request.auth.uid && 
                       incoming().timerStart == request.time;
                       
      allow update: if isVerified() && isValidId(incidentId) && isValidIncident(incoming()) && (isAdmin() || isCounsel()) && 
                       incoming().diff(existing()).affectedKeys().hasAny(['severity', 'status', 'notifiedAuthorities', 'updatedAt']) &&
                       incoming().updatedAt == request.time;
    }

    // 7. Global Settings (Admin Sensitive)
    function isValidGovernanceSettings(data) {
      return data.keys().hasAll(['scanMode']) &&
             data.scanMode in ['ON_DEMAND', 'WEEKLY'];
    }

    match /governance_settings/{settingsId} {
      allow read: if isSignedIn();
      allow write: if isVerified() && isValidId(settingsId) && isValidGovernanceSettings(incoming()) && (isAdmin() || isCompliance()); 
    }

    // 8. Market Leads (Enrichment and Scoring)
    function isValidLead(data) {
      return data.keys().hasAll(['companyName', 'status']) &&
             data.companyName is string && data.companyName.size() <= 256 &&
             data.status in ["qualified", "unqualified", "pending", "contacted"] &&
             (!data.keys().contains('website') || (data.website is string && data.website.size() <= 1000)) &&
             (!data.keys().contains('score') || data.score is number) &&
             (!data.keys().contains('owners') || (data.owners is list && data.owners.size() <= 100));
    }

    match /leads/{leadId} {
      allow read: if isSignedIn();
      
      allow create: if isVerified() && isValidId(leadId) && isValidLead(incoming()) && 
                       incoming().createdAt == request.time;
                       
      allow update: if isVerified() && isValidId(leadId) && isValidLead(incoming()) && (
        // Owners or Admin can update
        isAdmin() || (existing().keys().contains('owners') && request.auth.uid in existing().owners) ||
        // Allow updating if not strictly owner-restricted, but maintain immutable createdAt
        incoming().createdAt == existing().createdAt
      );
      
      allow delete: if isAdmin();
    }

    // 9. Stripe Managed Paths
    match /customers/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      match /subscriptions/{subscriptionId} {
        allow read: if isOwner(uid) || isAdmin();
      }
    }
    match /products/{productId} {
      allow read: if true;
      match /prices/{priceId} { allow read: if true; }
    }
  }
}
